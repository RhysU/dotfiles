#!/bin/bash
# Created because, on a 2-monitor system, Isonzo kept losing mouse focus
set -euo pipefail

RES=$(xrandr 2>/dev/null | awk '/\*/ {print $1; exit}')

if [[ -z "$RES" ]]; then
    echo "gamescope-auto: couldn't determine active resolution from xrandr" >&2
    exit 1
fi

W=${RES%%x*}
H=${RES##*x}

set -x
exec gamescope -w "$W" -h "$H" -W "$W" -H "$H" -s 2.9 --force-grab-cursor --force-windows-fullscreen "$@"
