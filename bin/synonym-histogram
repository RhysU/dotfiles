#!/usr/bin/env python3
# Copyright (c) 2026 Rhys Ulerich
# SPDX-License-Identifier: MPL-2.0
"""Print a histogram of NEEDLE and its synonyms over the given files or stdin.

Synonyms come from the Datamuse `rel_syn` endpoint, fetched via wget. Matching
is case-insensitive and handles multi-word synonyms such as "at that place"
for "there", with internal whitespace matching any run of whitespace so
phrases straddling line breaks still count. Input is processed as a stream
rather than slurped: a sliding bytearray buffer holds enough trailing text
that any phrase crossing a read boundary survives, with cuts taken at
whitespace via in-place left-trim and match counts deferred until a
successful cut to avoid double-counting near file boundaries. The matcher is
a bytes regex; Datamuse synonyms are ASCII, and UTF-8 input is safe because
non-ASCII characters never contain ASCII byte values, so word boundaries
behave the same as in text mode. Memory use is bounded by the longest
synonym plus one line, independent of input size.
"""

import argparse
import fileinput
import json
import re
import subprocess
import sys
from collections import Counter

API = "https://api.datamuse.com/words?rel_syn={}"


def fetch_synonyms(needle: str) -> list[str]:
    """Return synonyms for needle from Datamuse, ordered by API score."""
    result = subprocess.run(
        ["wget", "-qO-", API.format(needle)],
        capture_output=True,
        check=True,
        text=True,
    )
    return [entry["word"].lower() for entry in json.loads(result.stdout)]


def build_matcher(terms: list[str]) -> re.Pattern:
    """Compile an alternation matching any term as a whole word or phrase.

    Internal whitespace in a phrase matches any run of whitespace.
    Longest terms come first so 'at that place' wins over 'place'.
    Compiled as a bytes pattern so it can scan a bytearray buffer in place.
    """
    by_len = sorted(terms, key=len, reverse=True)
    parts = [r"\s+".join(re.escape(w) for w in t.split()) for t in by_len]
    pattern = (r"\b(?:" + "|".join(parts) + r")\b").encode("ascii")
    return re.compile(pattern, re.IGNORECASE)


WS_RE = re.compile(rb"\s")
WS_RUN = re.compile(rb"\s+")


def scan(stream, matcher: re.Pattern, max_term_len: int, counts: Counter) -> None:
    """Stream through input, counting matches without buffering everything.

    The buffer is a bytearray so appends and left-trims are in place. After
    each scan, the cut point is the later of the last match's end and
    len(buf) - max_term_len, advanced to the next whitespace so word
    boundaries behave the same as in a single slurp. Matches are committed
    to counts only after a successful cut, so a buffer without a viable cut
    point is rescanned in full next round without double-counting.
    """
    flush = 4 * max_term_len
    buf = bytearray()
    for line in stream:
        buf.extend(line)
        if len(buf) < flush:
            continue
        pending = []
        last_end = 0
        for match in matcher.finditer(buf):
            normalized = (
                WS_RUN.sub(b" ", match.group()).decode("ascii", "replace").lower()
            )
            pending.append(normalized)
            last_end = match.end()
        cut_floor = max(last_end, len(buf) - max_term_len)
        ws = WS_RE.search(buf, cut_floor)
        if ws is None:
            continue
        for term in pending:
            counts[term] += 1
        del buf[: ws.start()]
    for match in matcher.finditer(buf):
        counts[WS_RUN.sub(b" ", match.group()).decode("ascii", "replace").lower()] += 1


def histogram(counts: Counter, terms: list[str]) -> str:
    """Render terms in given order, one per line, with '#' bars."""
    width = max(len(t) for t in terms)
    return "\n".join(f"{term:<{width}} {'#' * counts[term]}" for term in terms)


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        prog="synonym-histogram",
        description="Print a histogram of NEEDLE and its synonyms over input.",
    )
    parser.add_argument("needle", metavar="NEEDLE", help="word to look up synonyms for")
    parser.add_argument(
        "files",
        metavar="FILE",
        nargs="*",
        help="input files; standard input is read when none are given",
    )
    args = parser.parse_args(argv[1:])

    needle = args.needle.lower()
    terms = [needle] + [s for s in fetch_synonyms(needle) if s != needle]
    matcher = build_matcher(terms)
    max_term_len = max(len(t) for t in terms)

    counts = Counter()
    with fileinput.input(files=args.files or ("-",), mode="rb") as stream:
        scan(stream, matcher, max_term_len, counts)

    print(histogram(counts, terms))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
